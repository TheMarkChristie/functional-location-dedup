<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>MarkChristie.FunctionalLocationDeduplicator</id>
    <version>1.0.2</version>
    <title>Functional Location De-duplicator</title>
    <authors>Mark Christie</authors>
    <owners>Mark Christie</owners>
    <projectUrl>https://github.com/TheMarkChristie/functional-location-dedup</projectUrl>
    <iconUrl>https://raw.githubusercontent.com/TheMarkChristie/functional-location-dedup/main/logo.png</iconUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <license type="expression">MIT</license>
    <description>Merge duplicate Functional Locations onto a master record. Find duplicates by Street 1 + Postcode, score each record by completeness + linked records + age, reallocate every linked record (Account, Work Order, Agreement, …) onto the highest-scoring master, verify, then deactivate or delete the duplicates.</description>
    <summary>Merge duplicate Functional Locations onto a master record.</summary>
    <releaseNotes>Initial release. WebView2-hosted Windows 95 UI; shared logic with the D365 web resource and PPTB tool.</releaseNotes>
    <tags>XrmToolBox Plugin Dataverse Dynamics365 FieldService FunctionalLocation Duplicates Merge</tags>
    <dependencies>
      <dependency id="XrmToolBox" version="1.2025.7.71" />
    </dependencies>
  </metadata>
  <files>
    <!-- Ship ONLY our own assembly + HTML; XrmToolBox provides WebView2 + the Dataverse SDK.
         The Tool Library extracts a "Plugins" folder into the user's XrmToolBox Plugins dir. -->
    <file src="bin\Release\net48\FunctionalLocationMerge.dll" target="Plugins" />
    <file src="bin\Release\net48\app\index.html" target="Plugins\app" />
  </files>
</package>
